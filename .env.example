HTTP_PROXY=''

# Container directories
APP_DIR_CONTR="/usr/src/questionsapp/"
LOGS_DIR_CONTR="/usr/src/logs/"
ATTACH_DIR_CONTR="/usr/src/attachments/"
DATA_DIR_CONTR="/usr/src/data/"

# Host directories (must exist)
APP_DIR_HOST="./"
LOGS_DIR_HOST="/mnt/c/Users/DevMethod/Documents/Projects/EDUPROJECT/logs/questionsapp/"
ATTACH_DIR_HOST="/mnt/c/Users/DevMethod/Documents/Projects/EDUPROJECT/attachments/"
